{
	"$defs": {
		"mode": {"type": "string", "enum": ["None", "D-Star", "DMR", "YSF", "P25", "NXDN", "FM", "???"]},
		"source": {"type": "string", "enum": ["RF", "Net"]},
		"action": {"type": "string", "enum": ["begin", "end", "lost"]},
		"callsign": {"type": "string", "minLength": 8, "maxLength": 10},
		"slot": {"type": "integer", "enum": [1, 2]},
		"id": {"type": "integer", "minimum": 1, "maximum": 16777215},
		"group": {"type": "string", "enum": ["yes", "no"]},
		"dg-id": {"type": "integer", "minimum": 0, "maximum": 99},
		"timestamp": {"type": "string"}
	},

	"Message": {
		"type": "object",
		"timestamp": {"$ref": "#/$defs/timestamp"},
		"message": {"type": "string"},
		"required": ["timestamp", "message"]
	},

	"Status": {
		"type": "object",
		"timestamp": {"$ref": "#/$defs/timestamp"},
		"src": {"$ref": "#/$defs/source"},
		"dst": {"$ref": "#/$defs/source"},
		"action": {"$ref": "#/$defs/action"},
		"RF": {"$ref": "#/Address"},
		"Net": {"$ref": "#/Address"},
		"required": ["timestamp", "action"]
	},
	
	"Address" : {
		"type": "object",
		"mode": {"$ref": "#/$defs/mode"},
		"src_callsign": {"$ref": "#/$defs/callsign"},
		"dst_callsign": {"$ref": "#/$defs/callsign"},
		"slot": {"$ref": "#/$defs/slot"},
		"src_id": {"$ref": "#/$defs/id"},
		"dst_id": {"$ref": "#/$defs/id"},
		"dg-id": {"$ref": "#/$defs/dg-id"},
		"group": {"$ref": "#/$defs/type"},
		"required": ["mode"]
	}
}
