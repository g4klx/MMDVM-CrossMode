{
	"$defs": {
		"mode": {"type": "string", "enum": ["none", "D-Star", "DMR", "YSF", "P25", "NXDN", "FM"]},
		"direction": {"type": "string", "enum": ["FROM -> TO", "FROM <- TO"]},
		"callsign": {"type": "string", "minLength": 8, "maxLength": 10},
		"slot": {"type": "integer", "enum": [1, 2]},
		"id": {"type": "integer", "minimum": 1, "maximum": 16777215},
		"group": {"type": "string", "enum": ["yes", "no"]},
		"dg-id": {"type": "integer", "minimum": 0, "maximum": 99},
		"timestamp": {"type": "string"}
	},

	"Message": {
		"type": "object",
		"timestamp": {"$ref": "#/$defs/timestamp"},
		"message": {"type": "string"},
		"required": ["timestamp", "message"]
	},

	"Status": {
		"type": "object",
		"timestamp": {"$ref": "#/$defs/timestamp"},
		"direction": {"$ref": "#/$defs/direction"},
		"from": {"type": "Destination"},
		"to": {"type": "Destination"},
		"required": ["timestamp"]
	},
	
	"Destination" : {
		"type": "object",
		"mode": {"$ref": "#/$defs/mode"},
		"src_callsign": {"$ref": "#/$defs/callsign"},
		"dst_callsign": {"$ref": "#/$defs/callsign"},
		"slot": {"$ref": "#/$defs/slot"},
		"src_id": {"$ref": "#/$defs/id"},
		"dst_id": {"$ref": "#/$defs/id"},
		"dg-id": {"$ref": "#/$defs/dg-id"},
		"group": {"$ref": "#/$defs/type"},
		"required": ["mode"]
	}
}
